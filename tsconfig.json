{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./build",

    "module": "Node16",
    "moduleResolution": "node16",
    "target": "ES2020",

    "types": ["node"],
    "esModuleInterop": true,
    "resolveJsonModule": true,

    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,

    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    "isolatedModules": true,
    "moduleDetection": "force",
    "skipLibCheck": true
  },
  "include": ["src"],
  "exclude": ["node_modules"]
}