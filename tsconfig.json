{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./build",

    "module": "Node16",        // ← change from ESNext
    "moduleResolution": "node16",  // ← change from bundler
    "target": "ES2020",          // ← esnext can cause issues in Node

    "types": ["node"],           // ← add this

    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,

    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    "strict": true,
    // "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "noUncheckedSideEffectImports": true,
    "moduleDetection": "force",
    "skipLibCheck": true,
  }
}